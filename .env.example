# --- Search criteria ---
# Comma-separated Vienna districts to monitor (Bezirk numbers).
DISTRICTS=2,3,6,7,8,9,17,18,19
# rent | buy
TRANSACTION_TYPE=rent
ROOMS_MIN=1
ROOMS_MAX=2

# --- Schedules (cron syntax) ---
# Poll willhaben every 45 minutes by default.
POLL_INTERVAL_CRON=*/45 * * * *
# Snapshot per-district stats just after midnight.
STATS_CRON=5 0 * * *
# Daily report at 08:00.
DAILY_REPORT_CRON=0 8 * * *
TZ=Europe/Vienna

# --- Alerting ---
# Fire an alert when a new listing is this fraction below the district median sqm price.
ALERT_THRESHOLD_PCT=0.15
# Trailing window (days) used to compute the district baseline median.
STATS_WINDOW_DAYS=30

# --- Storage / web ---
DB_PATH=data/listings.db
PORT=3000

# --- Email (Gmail SMTP with an app password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-address@gmail.com
# Recipients for below-market alerts and the daily report. Provide one address
# or a comma-separated list, e.g. "me@x.com, partner@y.com". Defaults to SMTP_USER.
ALERT_EMAIL_TO=your-address@gmail.com
REPORT_EMAIL_TO=your-address@gmail.com

# --- Scraper politeness ---
REQUEST_DELAY_MS=1500
MAX_PAGES_PER_DISTRICT=5
